# CT Travel Smart API key. CTDOT 511 system. Rate limit 10/60s.
# Sign up at the CTDOT developer portal.
CT_TRAVEL_SMART_API_KEY=

# Weather: no key required. We use Open-Meteo (https://open-meteo.com).

# Postgres (Neon, provisioned via Vercel Marketplace).
DATABASE_URL=

# Optional. Set to require Bearer auth on /api/cron/ingest.
CRON_SECRET=
