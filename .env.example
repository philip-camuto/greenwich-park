# =========================
# Required
# =========================

# Postgres (Neon, provisioned via Vercel Marketplace).
DATABASE_URL=

# CT Travel Smart API key. CTDOT 511 system. Rate limit 10/60s.
# Sign up at the CTDOT developer portal.
CT_TRAVEL_SMART_API_KEY=

# =========================
# Optional — sources degrade gracefully if missing
# =========================

# TomTom Traffic Flow Segment Data. Free tier covers our usage.
# https://developer.tomtom.com
TOMTOM_API_KEY=

# Ticketmaster Discovery API (event aggregator).
# https://developer.ticketmaster.com
TICKETMASTER_API_KEY=

# Eventbrite OAuth private token (event aggregator).
# https://www.eventbrite.com/platform
EVENTBRITE_API_KEY=

# MTA camsys serviceStatus key for real-time Metro-North alerts.
# Defaults to the public-website embedded key if unset; override here when
# rotating or moving to a private key.
MTA_CAMSYS_KEY=

# Weather: no key required. We use Open-Meteo.
# https://open-meteo.com

# =========================
# Auth
# =========================

# Bearer secret for /api/cron/ingest and /debug?key=...
# Without this, both endpoints are open. Set it in production.
CRON_SECRET=
